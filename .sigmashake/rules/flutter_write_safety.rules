# flutter_write_safety.rules
# Technology: flutter | Capability: write

rule flutter-block-unsafe-patterns {
  enabled true
  priority 90
  severity error
  DENY write
  IF path GLOB "**/*" AND content CONTAINS "UNSAFE_flutter_PATTERN"
  MESSAGE "Blocked an unsafe pattern in flutter. Use the recommended best practices for 2025/2026."
}

rule flutter-force-updated-api {
  enabled true
  priority 80
  severity warning
  ASK write
  IF path GLOB "**/*" AND content CONTAINS "OLD_flutter_API"
  MESSAGE "You are using an outdated API for flutter. Please upgrade to the newer API."
}
